{
  "title": "PetHealth Performance Intelligence",
  "panels": [
    {
      "title": "P99 Tail Latency",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(pet_registration_duration_bucket[5m])) by (le))"
        }
      ]
    },
    {
      "title": "P95 Latency",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(pet_registration_duration_bucket[5m])) by (le))"
        }
      ]
    },
    {
      "title": "Throughput (Req/Sec)",
      "targets": [{ "expr": "rate(http_server_duration_count[5m])" }]
    }
  ]
}
